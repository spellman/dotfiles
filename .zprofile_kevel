source "$HOME/Projects/dotfiles/env_functions"

# Inlined output of `/opt/homebrew/bin/brew shellenv` to avoid spawning brew
# (~40ms). If Homebrew changes its layout, re-run `brew shellenv` and update
# this block.
export HOMEBREW_PREFIX="/opt/homebrew"
export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
export HOMEBREW_REPOSITORY="/opt/homebrew"
fpath[1,0]="/opt/homebrew/share/zsh/site-functions"
path_prepend /opt/homebrew/sbin PATH
path_prepend /opt/homebrew/bin PATH
export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}"

# Use GNU coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin" PATH
fi

# Use GNU grep, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/grep/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/grep/libexec/gnubin" PATH
fi

# Use GNU sed, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin" PATH
fi

# Use GNU awk, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/gawk/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/gawk/libexec/gnubin" PATH
fi

# Use GNU gnu-indent, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/gnu-indent/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/gnu-indent/libexec/gnubin" PATH
fi

# Use GNU findutils, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/findutils/libexec/gnubin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/findutils/libexec/gnubin" PATH
fi

# Use GNU curl, which is not part of coreutils.
if [ -d "$HOMEBREW_PREFIX/opt/curl/bin" ]; then
  path_prepend "$HOMEBREW_PREFIX/opt/curl/bin" PATH
fi
