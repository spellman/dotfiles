# These are functions for manipulating PATH in shell config files such that the
# config file being loaded multiple times doesn't result in duplicate PATH
# entries.
# This allows using the Emacs package
# https://github.com/purcell/exec-path-from-shell to set environment variables
# for Emacs.
#
# These functions are zsh-specific. They use zsh parameter expansion instead of
# spawning subprocesses (the previous implementation ran `env | sed` for every
# call, which added ~100ms to shell startup across all the calls in the config
# files).

# Usage: indirect_expand PATH -> $PATH
indirect_expand () {
    print -r -- "${(P)1}"
}

# Usage: path_remove /path/to/bin [PATH]
# Eg, to remove ~/bin from $PATH
#     path_remove ~/bin PATH
path_remove () {
    local var=${2:-PATH}
    # Split the variable's value on colons into an array.
    local -a dirs
    dirs=("${(@s.:.)${(P)var}}")
    # Drop array elements equal to $1.
    dirs=("${(@)dirs:#$1}")
    # Join the remaining elements with colons.
    export $var="${(j.:.)dirs}"
}

# Usage: path_prepend /path/to/bin [PATH]
# Eg, to prepend ~/bin to $PATH
#     path_prepend ~/bin PATH
path_prepend () {
    # if the path is already in the variable,
    # remove it so we can move it to the front
    path_remove "$1" "$2"
    local var="${2:-PATH}"
    local value="${(P)var}"
    export ${var}="${1}${value:+:${value}}"
}

# Usage: path_append /path/to/bin [PATH]
# Eg, to append ~/bin to $PATH
#     path_append ~/bin PATH
path_append () {
    path_remove "${1}" "${2}"
    local var=${2:-PATH}
    local value="${(P)var}"
    export $var="${value:+${value}:}${1}"
}

# Usage: source_if_exists filename
source_if_exists () {
    # Test whether "$1" exists and is readable.
    if [ -r "$1" ]; then
        . "$1"
    fi
}
