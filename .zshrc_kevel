# There are multiple files. I want the value from the right file :)
alias aws-expires="jq '.expiresAt' ~/.aws/sso/cache/*.json"

# cdktf tab completion (cached; run `cdktf completion > ~/.zsh/completions/_cdktf` to refresh)
[[ -s "$HOME/.zsh/completions/_cdktf" ]] && . "$HOME/.zsh/completions/_cdktf"

alias ndss="put-network-deactivation-screenshot-names-in-clipboard"
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

export NVM_DIR="$HOME/.nvm"

# Put the latest installed node on PATH immediately so node/npm/npx
# work without loading nvm.sh (~1.4s). When NVM loads (via the nvm
# wrapper or .nvmrc), it takes over PATH management.
if [[ -d "$NVM_DIR/versions/node" ]]; then
  _nvm_latest=$(ls "$NVM_DIR/versions/node" | sort -V | tail -1)
  if [[ -n "$_nvm_latest" ]]; then
    path_prepend "$NVM_DIR/versions/node/$_nvm_latest/bin" PATH
  fi
  unset _nvm_latest
fi

_load_nvm() {
  unfunction nvm 2>/dev/null
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
}

nvm() {
  _load_nvm
  nvm "$@"
}

if [[ -f .nvmrc ]]; then
  _load_nvm
  nvm use --silent >/dev/null || nvm install --silent
fi

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
# bun completions
[ -s "/Users/cort/.bun/_bun" ] && source "/Users/cort/.bun/_bun"
