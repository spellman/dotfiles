fpath=("/Users/cort/.zsh/completions" $fpath)
autoload -Uz compinit
# Uses cached dump; run `rm -f ~/.zcompdump && compinit` to regenerate after installing new tools.
compinit -C
eval "$(starship init zsh)"

setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY

export HISTSIZE=1000000
export SAVEHIST=1000000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_REDUCE_BLANKS

# fzf fuzzy finder
source <(fzf --zsh)

# 3S `ls` command
if [ "$(command -v eza)" ]; then
  unalias -m 'll'
  unalias -m 'l'
  unalias -m 'la'
  # Don't remove this. Scripts use it with options supported by ls but not eza.
  # unalias -m 'ls'
  # alias ls='eza -G  --color auto --icons -a -s type'
  alias l='eza -l --color always --icons -a -s type'
fi

# Navigate between projects
p() {
  # TODO: Use fd instead of find?
  selected=$(find ~/Projects ~/Projects/dotfiles ~ -mindepth 1 -maxdepth 1 -type d | fzf --ansi)
  cd $selected
}

# Convert seconds since Unix epoch to UTC timestamp.
s2utc() {
  date -u -d @"${1}" +%Y-%m-%dT%H:%M:%SZ
}

# Convert milliseconds since Unix epoch to UTC timestamp.
ms2utc() {
  whole_seconds=$(($1 / 1000)) # integer division
  fractional_seconds=$(($1 % 1000))
  date -u -d @"${whole_seconds}.${fractional_seconds}" +%Y-%m-%dT%H:%M:%S.%3NZ
}

b64decode() {
  emulate -L zsh

  local decode_flag

  if base64 --help 2>&1 | grep -q -- "--decode"; then
    # GNU coreutils base64
    decode_flag="--decode"
  else
    # Mac base64
    decode_flag="-D"
  fi

  if [[ $# -gt 0 ]]; then
    printf "%s" "$1" | base64 "$decode_flag"
  else
    base64 "$decode_flag"
  fi
}

# Export JIRA ticket
t() {
  export TICKET="jira-${1}"
}

function file_ends_with_newline() {
    [[ $(tail -c1 "$1" | wc -l) -gt 0 ]]
}

# SSH
alias start_ssh_agent='eval "$(ssh-agent -s)"'

# Various
alias flush-dns="sudo killall -HUP mDNSResponder; sleep 2;"
alias ipaddress="ifconfig | grep inet"

# Java
# JAVA_HOME is resolved when the alias runs, not at shell startup.
# Note: java_home falls back to the newest installed JDK when the requested
# version is not installed.
alias java8='export JAVA_HOME=$(/usr/libexec/java_home -v 8)'
alias java11='export JAVA_HOME=$(/usr/libexec/java_home -v 11)'
alias java17='export JAVA_HOME=$(/usr/libexec/java_home -v 17)'
alias java21='export JAVA_HOME=$(/usr/libexec/java_home -v 21)'
alias java25='export JAVA_HOME=$(/usr/libexec/java_home -v 25)'

# default to Java 25
java25

